{
  "name": "the-swarm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "THE SWARM — Incremental game from ant queen to interstellar conquest",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "tsc --noEmit && vitest run && playwright test",
    "lint": "oxlint",
    "prepare": "sh scripts/setup-hooks.sh",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^2.0.0",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "oxlint": "^1.67.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@preact/signals-core": "^1.14.2"
  },
  "packageManager": "pnpm@11.5.0"
}
